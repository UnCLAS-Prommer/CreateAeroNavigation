  "create_aeronautics_navigation.ponder.tag.navigation": "Aeronautics Navigation",
  "create_aeronautics_navigation.ponder.tag.navigation.description": "Waypoints and route cards for Create: Aeronautics navigation tables",
  "create_aeronautics_navigation.ponder.vordme_beacon.header": "Marking VOR/DME Waypoints",
  "create_aeronautics_navigation.ponder.vordme_beacon.text_1": "VOR/DME Beacons mark fixed navigation waypoints in the world",
  "create_aeronautics_navigation.ponder.vordme_beacon.text_2": "Right-click a beacon with an empty hand to rename it",
  "create_aeronautics_navigation.ponder.vordme_beacon.text_3": "The beacon name is what Route Cards will record",
  "create_aeronautics_navigation.ponder.vordme_beacon.text_4": "Sneak-right-click the beacon with an empty hand to check its name and coordinates",
  "create_aeronautics_navigation.ponder.route_card_recording.header": "Recording Route Cards",
  "create_aeronautics_navigation.ponder.route_card_recording.text_1": "Route Cards store an ordered list of waypoints",
  "create_aeronautics_navigation.ponder.route_card_recording.text_2": "Right-click a VOR/DME Beacon with the card to append it to the end",
  "create_aeronautics_navigation.ponder.route_card_recording.text_3": "1. AERODROME-A",
  "create_aeronautics_navigation.ponder.route_card_recording.text_4": "1. AERODROME-A\n2. RIDGE-B",
  "create_aeronautics_navigation.ponder.route_card_recording.text_5": "1. AERODROME-A\n2. RIDGE-B\n3. HARBOR-C",
  "create_aeronautics_navigation.ponder.route_card_recording.text_6": "Record several beacons to build a route",
  "create_aeronautics_navigation.ponder.route_card_recording.text_7": "Right-click the air to open the editor",
  "create_aeronautics_navigation.ponder.route_card_recording.text_8": "The editor can reorder, delete, set targets, and add coordinate waypoints",
  "create_aeronautics_navigation.ponder.route_card_recording.text_9": "Sneak-right-click the air to clear the entire route",
  "create_aeronautics_navigation.ponder.route_card_recording.text_10": "Sneak-right-click a recorded beacon to remove only that beacon from the card",
  "create_aeronautics_navigation.ponder.route_card_navigation_table.header": "Navigating Routes",
  "create_aeronautics_navigation.ponder.route_card_navigation_table.text_1": "Insert a Route Card into the Aeronautics Navigation Table",
  "create_aeronautics_navigation.ponder.route_card_navigation_table.text_2": "The table targets the current waypoint on the card",
  "create_aeronautics_navigation.ponder.route_card_navigation_table.text_3": "When the craft reaches a waypoint, the card advances to the next one",
  "create_aeronautics_navigation.ponder.route_card_navigation_table.text_4": "The final waypoint completes the route",
  "create_aeronautics_navigation.ponder.route_card_navigation_table.text_5": "On completion, the Navigation Table emits redstone upward",
  "create_aeronautics_navigation.ponder.route_card_navigation_table.text_6": "Open the Route Card editor and press a row's target button to choose the current waypoint manually"
